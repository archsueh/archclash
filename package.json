{
  "name": "arch-clash",
  "version": "0.6.0",
  "license": "GPL-3.0-only",
  "scripts": {
    "prepare": "husky || true",
    "web:dev": "vite",
    "web:build": "tsc --noEmit && vite build",
    "web:serve": "vite preview",
    "copy:desktop-appicon": "node scripts/copy-desktop-appicon.mjs",
    "prebuild": "node scripts/prebuild.mjs",
    "prepare:wails": "node scripts/wails-prepare.mjs",
    "icons:windows": "node scripts/generate-windows-icon.mjs",
    "desktop:packaging": "node scripts/sync-desktop-packaging.mjs",
    "wails:dev": "node scripts/wails.mjs dev",
    "wails:build": "node scripts/wails.mjs build",
    "desktop:resources": "pnpm run copy:desktop-appicon && pnpm run test:required && pnpm run prebuild && pnpm run prepare:wails && pnpm run icons:windows && pnpm run desktop:packaging",
    "desktop:build:windows": "node scripts/wails.mjs build -platform windows/amd64 -clean -nsis",
    "desktop:build:windows:arm64": "node scripts/wails.mjs build -platform windows/arm64 -clean -nsis",
    "desktop:build:darwin:arm64": "node scripts/wails.mjs build -platform darwin/arm64 -clean",
    "desktop:build:darwin:amd64": "node scripts/wails.mjs build -platform darwin/amd64 -clean",
    "desktop:package:dmg": "node scripts/create-macos-dmg.mjs",
    "desktop:build:darwin:arm64:dmg": "pnpm run desktop:build:darwin:arm64 && pnpm run desktop:package:dmg",
    "desktop:build:darwin:amd64:dmg": "pnpm run desktop:build:darwin:amd64 && pnpm run desktop:package:dmg",
    "desktop:build:linux:amd64": "node scripts/wails.mjs build -platform linux/amd64 -clean -tags webkit2_41",
    "test:required": "node tests/required/run-required-tests.mjs",
    "updater": "node scripts/updater.mjs",
    "updater-fixed-webview2": "node scripts/updater-fixed-webview2.mjs",
    "fix-alpha-version": "node scripts/fix-alpha_version.mjs",
    "publish-version": "node scripts/publish-version.mjs",
    "lint": "eslint -c eslint.config.ts --max-warnings=0 --cache --cache-location .eslintcache apps/arch-clash-desktop/frontend/src",
    "lint:fix": "eslint -c eslint.config.ts --max-warnings=0 --cache --cache-location .eslintcache --fix apps/arch-clash-desktop/frontend/src",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "typecheck": "pnpm exec tsc --noEmit -p apps/arch-clash-desktop/frontend/tsconfig.json"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@juggle/resize-observer": "^3.4.0",
    "@monaco-editor/react": "^4.7.0",
    "@mui/icons-material": "^9.0.0",
    "@mui/lab": "9.0.0-beta.2",
    "@mui/material": "^9.0.0",
    "@tanstack/react-query": "^5.96.1",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.23",
    "ahooks": "^3.9.6",
    "cidr-block": "^2.3.0",
    "dayjs": "1.11.20",
    "foxact": "^0.3.0",
    "foxts": "^5.3.0",
    "i18next": "^26.0.0",
    "js-yaml": "^4.1.1",
    "lodash-es": "^4.17.23",
    "meta-json-schema": "^1.19.21",
    "monaco-editor": "^0.55.1",
    "monaco-yaml": "^5.4.1",
    "nanoid": "^5.1.7",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-error-boundary": "6.1.1",
    "react-hook-form": "^7.72.0",
    "react-i18next": "17.0.4",
    "react-markdown": "10.1.0",
    "react-router": "^7.17.0",
    "rehype-raw": "^7.0.0",
    "types-pac": "^1.0.3",
    "validator": "^13.15.26"
  },
  "devDependencies": {
    "@actions/github": "^9.0.0",
    "@biomejs/biome": "^2.4.10",
    "@eslint-react/eslint-plugin": "^4.0.0",
    "@eslint/js": "^10.0.1",
    "@types/js-yaml": "^4.0.9",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^24.12.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/validator": "^13.15.10",
    "@vitejs/plugin-legacy": "^8.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "adm-zip": "^0.5.16",
    "axios": "^1.13.6",
    "cli-color": "^2.0.4",
    "commander": "^14.0.3",
    "cross-env": "^10.1.0",
    "eslint": "^10.1.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-react-compiler": "19.1.0-rc.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-unused-imports": "^4.4.1",
    "glob": "^13.0.6",
    "globals": "^17.4.0",
    "https-proxy-agent": "^9.0.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "lint-staged": "^16.4.0",
    "node-fetch": "^3.3.2",
    "sass": "^1.98.0",
    "sharp": "^0.34.5",
    "tar": "^7.5.12",
    "terser": "^5.46.1",
    "to-ico": "^1.1.5",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.57.1",
    "vite": "^8.0.1",
    "vite-plugin-svgr": "^5.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs}": [
      "eslint -c eslint.config.ts --fix --max-warnings=0 --no-warn-ignored",
      "biome format --write"
    ],
    "*.{css,scss,json}": [
      "biome format --write"
    ]
  },
  "type": "module",
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "core-js",
      "es5-ext",
      "meta-json-schema",
      "sharp",
      "unrs-resolver"
    ],
    "overrides": {
      "dompurify@<3.3.2": "^3.4.8",
      "js-cookie@<3.0.6": "^3.0.8"
    }
  }
}
